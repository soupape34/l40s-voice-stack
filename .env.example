# vLLM — Gemma 4 26B-A4B
VLLM_MODEL=google/gemma-4-26B-A4B-it
VLLM_PORT=8000
VLLM_GPU=0
MAX_MODEL_LEN=8192
GPU_MEMORY_UTIL=0.78
# fp8 recommandé sur L40S 48Go ; mettre "none" si 2× L40S et BF16
VLLM_QUANTIZATION=fp8

# TTS — CustomVoice (Serena par défaut) + Base pour clone vocal
TTS_CUSTOM_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_CLONE_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
# 8001 is used by vLLM engine core; use 8002 for TTS HTTP
TTS_PORT=8002
TTS_GPU=0
TTS_SPEAKER=serena
TTS_LANGUAGE=French

# STT — Parakeet TDT 0.6B-v3 (défaut) ou whisper
STT_BACKEND=parakeet
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
PARAKEET_DEVICE=cuda
# Fallback Whisper (STT_BACKEND=whisper)
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=int8_float16

# Chat
VLLM_BASE_URL=http://localhost:8000/v1
TTS_BASE_URL=http://localhost:8002
LLM_MAX_TOKENS=128
SYSTEM_PROMPT="Tu es une assistante amicale. Réponds toujours en français, de façon concise (1-3 phrases)."

# Idle auto-stop EC2 (watchdog sur l'instance)
IDLE_MINUTES=30
IDLE_GRACE_MINUTES=15
IDLE_STOP_ENABLED=1
